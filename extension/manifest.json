{
  "manifest_version": 3,
  "name": "KEATS Downloader",
  "version": "1.1.0",
  "description": "Download all KEATS course materials in one click. Slides, videos, podcasts — organised into folders.",
  "permissions": [
    "downloads",
    "downloads.ui",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
